# Set LLM_MODE=mock to run the whole pipeline with MockLLMClient (no keys needed, default for local dev).
# Set LLM_MODE=real to wire AnthropicClient + FastLLMClient.
LLM_MODE=mock

# Vision extraction + synthesis (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-5

# Parallel debate agents (Arthur/Clara/Leo) - choose one provider
FAST_LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=

# Relationship Memory (Supabase Postgres + pgvector). Leave unset to use NoOpMemoryStore.
SUPABASE_DB_URL=

# Embeddings for Relationship Memory (see backend/memory/embeddings.py)
VOYAGE_API_KEY=
