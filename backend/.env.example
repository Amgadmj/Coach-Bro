# Set LLM_MODE=mock to run the whole pipeline with MockLLMClient (no keys needed, default for local dev).
# Set LLM_MODE=real to wire AnthropicClient + FastLLMClient.
LLM_MODE=mock

# Vision extraction + synthesis (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-5

# Parallel debate agents (Arthur/Clara/Leo) - choose one provider.
# "groq" or "gemini": fast/cheap, needs the matching key below.
# "anthropic": reuses the same Claude client as vision/synthesis - no extra key
# needed, pricier per call, but zero setup and not subject to Groq/Gemini's
# separate free-tier limits.
FAST_LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=

# Relationship Memory. Default: local SQLite at data/memory.db (zero config).
# Set SUPABASE_DB_URL to use Postgres/pgvector instead.
SUPABASE_DB_URL=
MEMORY_DB_PATH=data/memory.db

# Embeddings for Relationship Memory (pgvector path only; see backend/memory/embeddings.py)
VOYAGE_API_KEY=

# --- production hardening ---
# Comma-separated allowed origins for CORS; "*" is fine for local dev only.
ALLOWED_ORIGINS=*
ANALYZE_RATE_LIMIT_PER_HOUR=20
SUGGEST_RATE_LIMIT_PER_HOUR=60
